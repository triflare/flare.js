{
  "type": "module",
  "name": "minttw",
  "version": "1.0.0",
  "description": "A simple and painless custom TurboWarp extension development platform, powered by bundling.",
  "main": "build/extension.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:prod": "node scripts/build.js --production",
    "watch": "node scripts/build.js --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write src/",
    "fullstack": "npm run format && npm run lint && npm run build"
  },
  "keywords": [
    "turbowarp",
    "scratch",
    "extension"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "chokidar": "^5.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.0.0",
    "terser": "^5.46.1"
  }
}
